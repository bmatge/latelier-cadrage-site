# Domaine servi par Traefik.
DOMAIN=portail-elec.matge.com

# Nom du certresolver dans la config Traefik (statique). À adapter si différent.
CERT_RESOLVER=letsencrypt

# Noms des entrypoints Traefik. Standard : web (80) et websecure (443).
WEB_ENTRYPOINT=web
WEBSECURE_ENTRYPOINT=websecure

# --- POC cadrage IA via Albert (DINUM/Etalab) — optionnel ---
# Active la route POST /api/cadrage/generate. Sans ce flag, la route est
# absente et le code Albert n'est jamais initialisé.
CADRAGE_ENABLED=0

# URL racine de l'API Albert (OpenAI-compatible). Pas de slash final.
# Exemple : https://albert.api.etalab.gouv.fr
ALBERT_API_URL=

# Clé API Albert (Bearer). À demander via la console Albert. JAMAIS commitée.
ALBERT_API_KEY=

# Modèle à utiliser. gpt-oss-120b par défaut.
ALBERT_MODEL=gpt-oss-120b

# Température (0.0 = déterministe, 1.0 = créatif). 0.3 par défaut pour
# privilégier la fidélité au format JSON.
ALBERT_TEMPERATURE=0.3
