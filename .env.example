# Variables d'interpolation du docker-compose agnostique.
#
# En PROD (VPS VibeLab), l'orchestrateur `spawn` injecte APP_NAME, DOMAIN,
# MAIL_HOST et MAIL_PORT — tu n'as à mettre ici que les SECRETS et options
# (bootstrap admin, From, Albert). En LOCAL (`docker compose up` autonome),
# définis aussi APP_NAME/DOMAIN si tu veux un routage Traefik.

# --- Local seulement (fournis par spawn en prod) ---
# APP_NAME=latelier
# DOMAIN=latelier.localhost
# MAIL_HOST=mailer
# MAIL_PORT=1025

# --- Bootstrap admin ---
# Emails (séparés par virgules) promus admin global au boot (idempotent).
BOOTSTRAP_ADMIN_EMAILS=

# --- Mail (magic-links) ---
# L'expéditeur DOIT être @miweb.run pour la signature DKIM du smtp-relay
# en mode pilote (`spawn --mail real`).
SMTP_FROM=latelier-noreply@miweb.run
SMTP_FROM_NAME=L'atelier
# Réponse routée ailleurs que sur la boîte technique (optionnel).
# SMTP_REPLY_TO=bertrand@matge.com

# --- POC cadrage IA via Albert (DINUM/Etalab) — optionnel ---
# Active la route POST /api/cadrage/generate. Sans CADRAGE_ENABLED=1, la
# route est absente et le code Albert n'est jamais initialisé.
CADRAGE_ENABLED=0
# URL racine de l'API Albert (OpenAI-compatible), sans slash final.
ALBERT_API_URL=
# Clé API Albert (Bearer). JAMAIS commitée.
ALBERT_API_KEY=
ALBERT_MODEL=gpt-oss-120b
ALBERT_TEMPERATURE=0.3
