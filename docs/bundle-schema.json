{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latelier.bercy.matge.com/schemas/bundle.json",
  "title": "L'atelier — Bundle d'import projet",
  "description": "Format d'export/import d'un projet (version 1). Cf. docs/bundle-format.md pour la spec narrative et docs/bundle-example.json pour un exemple complet. Source de vérité du code : server/src/services/project.service.ts.",
  "type": "object",
  "required": ["version", "project"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "exported_at": {
      "type": "string",
      "description": "ISO 8601 (informatif, non rejoué à l'import)."
    },
    "project": { "$ref": "#/$defs/project" },
    "tree": { "$ref": "#/$defs/treeRoot" },
    "roadmap": { "$ref": "#/$defs/roadmap" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "description": "Catalogues projet. Seules ces 6 clés sont persistées (cf. allow-list dans server/src/services/data.service.ts). Les clés inconnues sont silencieusement ignorées à l'import.",
      "properties": {
        "vocab":            { "$ref": "#/$defs/vocab" },
        "dispositifs":      { "$ref": "#/$defs/dispositifsCatalog" },
        "mesures":          { "$ref": "#/$defs/mesuresCatalog" },
        "objectifs":        { "$ref": "#/$defs/objectifsCatalog" },
        "drupal_structure": { "$ref": "#/$defs/drupalStructure" },
        "user_stories":     { "$ref": "#/$defs/userStoriesCatalog" }
      }
    }
  },
  "$defs": {
    "project": {
      "type": "object",
      "required": ["slug", "name"],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]{0,48}[a-z0-9])?$",
          "maxLength": 50
        },
        "name":        { "type": "string", "minLength": 1, "maxLength": 100 },
        "description": { "type": "string", "maxLength": 500 }
      }
    },

    "vocabKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Clé technique d'une entrée de vocabulaire. Convention : kebab-case ASCII (résultat de slugify(label))."
    },
    "vocabEntry": {
      "type": "object",
      "required": ["key", "label"],
      "additionalProperties": false,
      "properties": {
        "key":   { "$ref": "#/$defs/vocabKey" },
        "label": { "type": "string", "minLength": 1 }
      }
    },
    "vocab": {
      "type": "object",
      "description": "Vocabulaires éditables par projet (cf. ADR-009). Sert de source unique pour les références audiences/deadlines/page_types posées sur les nœuds et les mesures. `story_themes` (optionnel) est consommé par /parcours (cf. ADR-018).",
      "additionalProperties": false,
      "properties": {
        "audiences":    { "type": "array", "items": { "$ref": "#/$defs/vocabEntry" } },
        "deadlines":    { "type": "array", "items": { "$ref": "#/$defs/vocabEntry" } },
        "page_types":   { "type": "array", "items": { "$ref": "#/$defs/vocabEntry" } },
        "story_themes": { "type": "array", "items": { "$ref": "#/$defs/vocabEntry" } }
      }
    },

    "vocabRef": {
      "type": "string",
      "minLength": 1,
      "description": "Référence vers une `vocab.*.[].key` du même bundle. Validation runtime côté UI ; la validation de schéma est volontairement permissive (le vocab est libre par projet — cf. ADR-009)."
    },

    "stringOrLabeled": {
      "description": "Label simple : soit une string, soit un objet { label, key?, id?, name? } — les LLM ont tendance à promouvoir des listes de labels en objets {key,label}. Normalisé en string (extraction de `.label || .name || .id`) au boundary import/write côté serveur.",
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": true,
          "anyOf": [
            { "required": ["label"] },
            { "required": ["name"] },
            { "required": ["id"] }
          ]
        }
      ]
    },

    "treeRoot": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": true,
      "properties": {
        "id":    { "const": "root" },
        "label": { "type": "string", "minLength": 1 },
        "type":  { "$ref": "#/$defs/vocabRef" },
        "types": { "type": "array", "items": { "$ref": "#/$defs/vocabRef" } },
        "tldr":  { "type": "string" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/treeNode" }
        }
      }
    },

    "treeNode": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": true,
      "description": "additionalProperties: true — les nœuds portent aussi des champs maquette/commentaires/improvements/etc. ajoutés par les pages Vue (cf. ProjectMaquettePage). Cf. champs documentés en `properties` pour le contrat de base.",
      "properties": {
        "id":     { "type": "string", "minLength": 1 },
        "label":  { "type": "string", "minLength": 1 },
        "type":   { "$ref": "#/$defs/vocabRef", "description": "Legacy — préférer types[]." },
        "types":  { "type": "array", "items": { "$ref": "#/$defs/vocabRef" } },
        "tldr":   { "type": "string" },
        "format": { "type": "string" },
        "url":    { "type": "string" },
        "deadline":   { "$ref": "#/$defs/vocabRef" },
        "time_tech":  { "type": ["number", "null"] },
        "time_edito": { "type": ["number", "null"] },
        "auth":       { "type": "boolean" },
        "audiences":   { "type": "array", "items": { "$ref": "#/$defs/vocabRef" } },
        "dispositifs": { "type": "array", "items": { "type": "string" } },
        "mesures":     { "type": "array", "items": { "type": "string" } },
        "blocks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "additionalProperties": true,
            "properties": {
              "id":          { "type": "string" },
              "title":       { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "improvements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "additionalProperties": true,
            "properties": {
              "id":          { "type": "string" },
              "deadline":    { "$ref": "#/$defs/vocabRef" },
              "title":       { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "children": { "type": "array", "items": { "$ref": "#/$defs/treeNode" } }
      }
    },

    "roadmap": {
      "type": "object",
      "required": ["items"],
      "additionalProperties": false,
      "properties": {
        "meta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title":    { "type": "string" },
            "subtitle": { "type": "string" },
            "calendrier": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "label"],
                "additionalProperties": false,
                "properties": {
                  "id":       { "type": "string" },
                  "label":    { "type": "string" },
                  "echeance": { "type": "string" }
                }
              }
            },
            "actions": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "label"],
                "additionalProperties": false,
                "properties": {
                  "id":    { "type": "string" },
                  "label": { "type": "string" },
                  "desc":  { "type": "string" }
                }
              }
            }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "slice", "action", "story"],
            "additionalProperties": false,
            "properties": {
              "id":     { "type": "string" },
              "slice":  { "type": "string", "description": "Réfère à meta.calendrier[].id" },
              "action": { "type": "string", "description": "Réfère à meta.actions[].id" },
              "story":  { "type": "string" },
              "status": { "type": "string" },
              "notes":  { "type": "string" },
              "nodes":       { "type": "array", "items": { "type": "string" } },
              "dispositifs": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },

    "dispositifsCatalog": {
      "type": "object",
      "required": ["dispositifs"],
      "additionalProperties": false,
      "properties": {
        "meta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title":               { "type": "string" },
            "context":             { "type": "string" },
            "date":                { "type": "string" },
            "version":             { "type": "number" },
            "categories":          { "type": "array", "items": { "$ref": "#/$defs/stringOrLabeled" } },
            "note_methodologique": { "type": "string" }
          }
        },
        "dispositifs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "additionalProperties": false,
            "properties": {
              "id":           { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$" },
              "category":     { "type": "string" },
              "audiences":    { "type": "array", "items": { "$ref": "#/$defs/vocabRef" } },
              "audience":     { "type": "string", "description": "Legacy — préférer audiences[]. Normalisé en audiences:[audience] à l'import (cf. server/src/services/project.service.ts)." },
              "name":         { "type": "string" },
              "url":          { "type": "string" },
              "tel":          { "type": "string" },
              "description":  { "type": "string" },
              "porteur":      { "type": "string" },
              "tutelle":      { "type": "string" },
              "type":         { "type": "string" },
              "reutilisable": { "type": "string" },
              "maturite":     { "type": "string" },
              "commentaire":  { "type": "string" }
            }
          }
        }
      }
    },

    "mesuresCatalog": {
      "type": "object",
      "required": ["mesures"],
      "additionalProperties": false,
      "properties": {
        "meta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title":  { "type": "string" },
            "source": { "type": "string" },
            "axes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "label"],
                "additionalProperties": false,
                "properties": {
                  "id":    { "type": "string" },
                  "label": { "type": "string" }
                }
              }
            },
            "objectifs": {
              "type": "object",
              "description": "Map { [axeId]: [{ id, label }, …] }",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "label"],
                  "additionalProperties": false,
                  "properties": {
                    "id":    { "type": "string" },
                    "label": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "mesures": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "axe"],
            "additionalProperties": false,
            "properties": {
              "id":               { "type": "string" },
              "axe":              { "type": "string" },
              "objectif":         { "type": ["string", "null"] },
              "title":            { "type": "string" },
              "summary":          { "type": "string" },
              "description":      { "type": "string" },
              "qui":              { "type": "string" },
              "quand":            { "type": "string" },
              "objectif_chiffre": { "type": "string" },
              "audiences":        { "type": "array", "items": { "$ref": "#/$defs/vocabRef" } },
              "deadline":         { "$ref": "#/$defs/vocabRef" }
            }
          }
        }
      }
    },

    "objectifsCatalog": {
      "type": "object",
      "required": ["axes"],
      "additionalProperties": false,
      "description": "Pyramide stratégique imbriquée axes[].objectives[].means[]. Format unique (cf. project.service.ts fallback `{ axes: [] }`).",
      "properties": {
        "meta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title":    { "type": "string" },
            "promise":  { "type": "string" },
            "subtitle": { "type": "string" },
            "note":     { "type": "string" },
            "calendrier": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "label"],
                "additionalProperties": false,
                "properties": {
                  "id":       { "type": "string" },
                  "label":    { "type": "string" },
                  "echeance": { "type": "string" }
                }
              }
            }
          }
        },
        "axes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "additionalProperties": false,
            "properties": {
              "id":          { "type": "string" },
              "name":        { "type": "string" },
              "description": { "type": "string" },
              "objectives": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "name"],
                  "additionalProperties": false,
                  "properties": {
                    "id":   { "type": "string" },
                    "name": { "type": "string" },
                    "means": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["id", "text"],
                        "additionalProperties": false,
                        "properties": {
                          "id":          { "type": "string" },
                          "text":        { "type": "string" },
                          "nodes":       { "type": "array", "items": { "type": "string" } },
                          "dispositifs": { "type": "array", "items": { "type": "string" } }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },

    "drupalStructure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "content_types": { "type": "array", "items": { "$ref": "#/$defs/stringOrLabeled" } },
        "paragraphs": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "accordion", "tabs", "cards-row", "tiles-row", "auto-list", "summary",
              "button", "highlight", "callout", "image-text", "quote", "table",
              "video", "download-block", "download-links", "cards-download", "code"
            ]
          }
        },
        "paragraph_labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "taxonomies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "label", "options"],
            "additionalProperties": false,
            "properties": {
              "key":     { "type": "string" },
              "label":   { "type": "string" },
              "multi":   { "type": "boolean" },
              "options": { "type": "array", "items": { "$ref": "#/$defs/stringOrLabeled" } }
            }
          }
        }
      }
    },

    "userStoriesCatalog": {
      "type": "object",
      "description": "Parcours utilisateur : 2 niveaux. Niveau 1 = `parcours[]` (groupes thématiques, ex. Onboarding / Réclamation). Niveau 2 = `parcours[].stories[]` (user stories, tâches usagers avec leur suite d'écrans). Cf. ADR-018 et shared/src/user-stories.ts pour la sémantique. Un bundle legacy `{ stories: [...] }` (modèle plat antérieur à 2026-05-22) est toléré en entrée et migré vers `{ parcours: [{ id: 'p-default', label: 'Sans groupe', stories: [...] }] }` au boundary import.",
      "additionalProperties": false,
      "properties": {
        "parcours": {
          "type": "array",
          "items": { "$ref": "#/$defs/userParcours" }
        },
        "stories": {
          "type": "array",
          "description": "DEPRECATED : modèle plat antérieur à 2026-05-22. Migré automatiquement à l'import vers un parcours par défaut.",
          "items": { "$ref": "#/$defs/userStory" }
        }
      }
    },

    "userParcours": {
      "type": "object",
      "required": ["id", "label", "stories"],
      "additionalProperties": false,
      "description": "Groupe thématique de user stories.",
      "properties": {
        "id":          { "type": "string", "minLength": 1 },
        "label":       { "type": "string" },
        "description": { "type": "string" },
        "collapsed":   { "type": "boolean", "description": "État replié/déplié persisté." },
        "stories": {
          "type": "array",
          "items": { "$ref": "#/$defs/userStory" }
        }
      }
    },

    "userStory": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string", "minLength": 1 },
        "label":         { "type": "string" },
        "audience_key":  { "type": ["string", "null"], "description": "Clé de vocab.audiences." },
        "description":   { "type": "string" },
        "collapsed":     { "type": "boolean", "description": "État replié/déplié persisté de l'accordéon Parcours." },
        "theme_key":     { "type": ["string", "null"], "description": "DEPRECATED : ancien emplacement du thème (migré au niveau screen au normalize). Toléré en entrée pour les bundles antérieurs." },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/userStoryStep" }
        }
      }
    },

    "userStoryStep": {
      "type": "object",
      "required": ["id", "screen"],
      "additionalProperties": false,
      "properties": {
        "id":      { "type": "string", "minLength": 1 },
        "screen":  { "$ref": "#/$defs/userStoryScreen" },
        "action":  { "type": "string" },
        "comment": { "type": "string" },
        "branches": {
          "type": "array",
          "description": "Embranchements conditionnels. Profondeur 1 verrouillée — les leaf steps des branches ne portent pas `branches`.",
          "items": {
            "type": "object",
            "required": ["id", "condition", "steps"],
            "additionalProperties": false,
            "properties": {
              "id":        { "type": "string", "minLength": 1 },
              "condition": { "type": "string" },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "screen"],
                  "additionalProperties": false,
                  "properties": {
                    "id":      { "type": "string", "minLength": 1 },
                    "screen":  { "$ref": "#/$defs/userStoryScreen" },
                    "action":  { "type": "string" },
                    "comment": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "userStoryScreen": {
      "type": "object",
      "required": ["kind", "ref"],
      "additionalProperties": false,
      "description": "Référence polymorphe. `ref` est : un node.id pour kind='node', \"nodeId#paragraphId\" pour kind='block', un dispositif.id pour kind='dispositif', null pour kind='ghost'.",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["ghost", "node", "block", "dispositif"]
        },
        "ref":         { "type": ["string", "null"] },
        "title":       { "type": "string", "description": "Affichage rapide (mode ghost ou cache du label de l'entité référente)." },
        "description": { "type": "string", "description": "Description libre (mode ghost — repris à la promotion)." },
        "theme_key":   { "type": ["string", "null"], "description": "Thème de l'écran : clé de vocab.story_themes. Caractérise la nature de l'écran (navigation/information/action/transaction…), pas de la user story qui le traverse." }
      }
    }
  }
}
